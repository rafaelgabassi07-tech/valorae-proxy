{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true
  },
  "include": [
    "api/**/*.js",
    "routes/**/*.js",
    "lib/**/*.js",
    "lib/**/*.d.ts",
    "lib/**/*.ts",
    "public/sdk/typescript/**/*.ts"
  ],
  "exclude": ["node_modules", ".vercel"]
}
